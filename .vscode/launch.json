{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Expo",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/expo/AppEntry.js",
      "cwd": "${workspaceFolder}",
      "env": {
        "EXPO_DEBUG": "true"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Debug React Native",
      "type": "reactnative",
      "request": "launch",
      "platform": "android"
    },
    {
      "name": "Debug React Native iOS",
      "type": "reactnative",
      "request": "launch",
      "platform": "ios"
    }
  ]
} 